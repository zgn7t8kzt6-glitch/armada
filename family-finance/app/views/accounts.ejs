<%- include('header', {title:'Accounts'}) %>
<h1>Accounts &amp; net worth</h1>
<% if (plaid) { %>
<div class="card">
  <h2>Connected banks</h2>
  <% for (const b of banks) { %>
    <p><b><%= b.institution || 'Bank' %></b> —
      <% if (b.status === 'error') { %><span class="warn">connection error — relink below</span>
      <% } else if (b.stale) { %><span class="warn">⚠ stale: last synced <%= b.last_synced_at ? new Date(b.last_synced_at).toLocaleString() : 'never' %></span>
      <% } else { %><span class="good">synced <%= new Date(b.last_synced_at).toLocaleString() %></span><% } %>
    </p>
  <% } %>
  <% if (!banks.length) { %><p class="dim">No banks connected yet.</p><% } %>
  <div class="row">
    <button id="plaidLink" class="btn">🔗 Connect a bank<%= plaidEnv === 'sandbox' ? ' (sandbox)' : '' %></button>
    <form method="post" action="/plaid/sync"><button>Sync now</button></form>
  </div>
  <p class="dim small">You log in on your bank's own screen inside Plaid — FamilyOS never sees the password, only read-only balances and transactions. Balances show “as of” their last sync; anything older than 48 hours is flagged, never silent.</p>
</div>
<script src="https://cdn.plaid.com/link/v2/stable/link-initialize.js"></script>
<script>
document.getElementById('plaidLink').addEventListener('click', async () => {
  const r = await fetch('/plaid/link-token'); const d = await r.json();
  if (d.error) return alert(d.error);
  Plaid.create({ token: d.link_token, onSuccess: async (public_token, meta) => {
    await fetch('/plaid/exchange', { method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ public_token, institution: meta.institution && meta.institution.name }) });
    location.reload();
  }}).open();
});
</script>
<% } else { %>
<div class="banner">🔗 <b>Bank sync is ready to switch on.</b> Create a free account at plaid.com, then add
<code>PLAID_CLIENT_ID</code>, <code>PLAID_SECRET</code>, and <code>PLAID_ENV</code> to the server environment —
the “Connect a bank” button appears here automatically. Until then, CSV import below works today.</div>
<% } %>
<div class="card">
  <table>
    <tr><th>Account</th><th>Type</th><th class="num">Value</th><th>As of</th><th></th></tr>
    <% for (const a of accounts) { %>
      <tr class="<%= a.stale ? 'stale' : '' %>">
        <td><b><%= a.name %></b><% if (!a.liquidity_flag) { %> <span class="pill">illiquid</span><% } %></td>
        <td class="dim"><%= a.type %></td>
        <td class="num"><%= fmt(a.valuation) %></td>
        <td class="dim"><%= new Date(a.valued_at).toLocaleDateString() %><%= a.stale ? ' ⚠' : '' %></td>
        <td class="row">
          <form method="post" action="/accounts/<%= a.id %>" class="inline">
            <input class="tiny" name="valuation" placeholder="new value">
            <input type="hidden" name="is_debt" value="<%= a.valuation < 0 ? '1' : '' %>">
            <button class="mini">revalue</button>
          </form>
          <a class="mini btn" href="/accounts/<%= a.id %>/import">import CSV</a>
          <form method="post" action="/accounts/<%= a.id %>" class="inline"><button class="mini" name="archive" value="1">archive</button></form>
        </td>
      </tr>
    <% } %>
  </table>
</div>
<div class="card">
  <h2>Add account</h2>
  <form method="post" action="/accounts" class="row">
    <label>Name <input name="name" required placeholder="Chase checking"></label>
    <label>Type <select name="type"><option>checking</option><option>savings</option><option>credit</option><option>loan</option><option>brokerage</option><option>retirement</option><option>realestate</option><option>business</option><option>cash</option></select></label>
    <label>Value <input name="valuation" placeholder="$12,000"></label>
    <label class="check"><input type="checkbox" name="is_debt" value="1"> debt (negative)</label>
    <label class="check"><input type="checkbox" name="illiquid" value="1"> illiquid</label>
    <button>Add</button>
  </form>
</div>
<% if (snaps.length) { %>
<div class="card"><h2>Net worth history</h2>
  <table><tr><th>Date</th><th class="num">Snapshot total</th></tr>
  <% for (const s of snaps) { %><tr><td><%= new Date(s.as_of).toLocaleDateString() %></td><td class="num"><%= fmt(s.net) %></td></tr><% } %>
  </table>
</div>
<% } %>
<%- include('footer') %>
