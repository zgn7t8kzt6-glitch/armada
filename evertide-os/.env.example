# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server only. NEVER expose to the browser. Used by seed
# scripts, cron routes, and admin server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string (Supabase dashboard → Database → Connection
# string, "URI"). Used only by scripts/seed.ts and scripts/verify-seed.ts.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# ── App ─────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used in magic-link redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret protecting /api/cron/* routes. Vercel sends it automatically as
# `Authorization: Bearer $CRON_SECRET` when configured in project env vars.
CRON_SECRET=generate-a-long-random-string

# ── Development / testing only ──────────────────────────────────────────────
# Enables the password-less test-auth endpoint for Playwright. Must NEVER be
# set in production; the code also refuses it when NODE_ENV=production.
# ALLOW_TEST_AUTH=1
