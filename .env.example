# Copy to .env for local development (.env is gitignored — never commit real values).
# Every variable here is validated by packages/env; apps refuse to boot on invalid config.
# SECURITY: no production credentials, no production PHI, synthetic/local values only.

NODE_ENV=development
LOG_LEVEL=debug

# apps/api
API_PORT=3000
API_HOST=127.0.0.1

# Local docker-compose services (infrastructure/docker/docker-compose.dev.yml)
DATABASE_URL=postgresql://armada:armada_dev_only@localhost:5432/armada_dev
REDIS_URL=redis://localhost:6379

# Feature flags (all default OFF; override per-flag for local work only)
# ARMADA_FLAG_EXAMPLE_FLAG=true
